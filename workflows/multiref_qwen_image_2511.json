{
  "_doc": "Multi-reference compose. multiref.run pre-stitches N references into a single grid image and uploads it as ref_grid.png; this workflow loads that one image, scales to 1.05 MP, encodes via TextEncodeQwenImageEditPlus.image1, and regenerates from an empty latent (denoise=1.0) so the model composes from scratch using the grid as conditioning. The image2/image3 slots on TextEncodeQwenImageEditPlus are intentionally NOT used — empirically the encoder weights image1 overwhelmingly and the additional slots are effectively no-ops.",
  "3": {
    "inputs": {
      "seed": 0,
      "steps": 20,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["37", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["116", 0]
    },
    "class_type": "KSampler"
  },
  "100": {
    "inputs": {
      "image": "ref_grid.png"
    },
    "class_type": "LoadImage"
  },
  "110": {
    "inputs": {
      "upscale_method": "lanczos",
      "megapixels": 1.05,
      "image": ["100", 0]
    },
    "class_type": "ImageScaleToTotalPixels"
  },
  "116": {
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "class_type": "EmptySD3LatentImage"
  },
  "6": {
    "inputs": {
      "prompt": "compose using the references",
      "clip": ["38", 0],
      "vae": ["39", 0],
      "image1": ["110", 0]
    },
    "class_type": "TextEncodeQwenImageEditPlus"
  },
  "7": {
    "inputs": {
      "prompt": "low quality, blurry",
      "clip": ["38", 0],
      "vae": ["39", 0],
      "image1": ["110", 0]
    },
    "class_type": "TextEncodeQwenImageEditPlus"
  },
  "8": {
    "inputs": {
      "samples": ["3", 0],
      "vae": ["39", 0]
    },
    "class_type": "VAEDecode"
  },
  "9": {
    "inputs": {
      "filename_prefix": "protobanana-multiref",
      "images": ["8", 0]
    },
    "class_type": "SaveImage"
  },
  "37": {
    "inputs": {
      "unet_name": "qwen_image_edit_2511_fp8mixed.safetensors",
      "weight_dtype": "default"
    },
    "class_type": "UNETLoader"
  },
  "38": {
    "inputs": {
      "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
      "type": "qwen_image"
    },
    "class_type": "CLIPLoader"
  },
  "39": {
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    },
    "class_type": "VAELoader"
  }
}
